generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────
// USER & AUTH
// ─────────────────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  emailVerified   DateTime?
  passwordHash    String?
  firstName       String
  lastName        String
  phone           String?
  country         String
  dateOfBirth     DateTime?
  role            UserRole  @default(CUSTOMER)
  tier            UserTier  @default(STANDARD)
  kycStatus       KycStatus @default(NOT_STARTED)
  referralCode    String    @unique @default(cuid())
  referredById    String?
  referredBy      User?     @relation("Referrals", fields: [referredById], references: [id])
  referrals       User[]    @relation("Referrals")

  accounts        Account[]
  sessions        Session[]
  recipients      Recipient[]
  transfers       Transfer[]
  walletAccounts  WalletAccount[]
  kycDocuments    KycDocument[]
  notifications   Notification[]
  rewardPoints    RewardPointLedger[]
  apiKeys         ApiKey[]

  subscriptionTier   SubscriptionTier @default(FREE)
  subscriptionExpiry DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([referralCode])
  @@index([country])
}

enum UserRole {
  CUSTOMER
  BUSINESS
  ADMIN
  SUPER_ADMIN
}

enum UserTier {
  STANDARD
  SILVER
  GOLD
  PLATINUM
}

enum KycStatus {
  NOT_STARTED
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
  EXPIRED
}

enum SubscriptionTier {
  FREE
  PLUS
  PREMIUM
  BUSINESS
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────────────────
// KYC
// ─────────────────────────────────────────────────────────

model KycDocument {
  id           String          @id @default(cuid())
  userId       String
  user         User            @relation(fields: [userId], references: [id])
  documentType KycDocumentType
  fileUrl      String
  status       KycDocStatus    @default(PENDING)
  reviewNotes  String?
  reviewedBy   String?
  reviewedAt   DateTime?
  expiryDate   DateTime?
  createdAt    DateTime        @default(now())

  @@index([userId, status])
}

enum KycDocumentType {
  PASSPORT
  NATIONAL_ID
  DRIVERS_LICENSE
  PROOF_OF_ADDRESS
  SELFIE
}

enum KycDocStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─────────────────────────────────────────────────────────
// GEOGRAPHY & CORRIDORS
// ─────────────────────────────────────────────────────────

model Country {
  id              String   @id
  name            String
  currency        String
  phoneCode       String
  flagEmoji       String
  isActive        Boolean  @default(true)
  isSendFrom      Boolean  @default(false)
  isReceiveIn     Boolean  @default(false)
  deliveryMethods CountryDeliveryMethod[]

  @@index([isActive, isSendFrom])
  @@index([isActive, isReceiveIn])
}

model CountryDeliveryMethod {
  id             String         @id @default(cuid())
  countryId      String
  country        Country        @relation(fields: [countryId], references: [id])
  deliveryMethod DeliveryMethod
  isActive       Boolean        @default(true)
  partnerCode    String?

  @@unique([countryId, deliveryMethod])
}

enum DeliveryMethod {
  BANK_DEPOSIT
  MOBILE_WALLET
  CASH_PICKUP
  AIRTIME_TOPUP
  HOME_DELIVERY
}

model Corridor {
  id                String   @id @default(cuid())
  sendCountry       String
  receiveCountry    String
  sendCurrency      String
  receiveCurrency   String
  isActive          Boolean  @default(true)
  fxMarkupPercent   Decimal  @default(1.5)
  minTransferAmount Decimal
  maxTransferAmount Decimal
  dailyLimit        Decimal
  monthlyLimit      Decimal

  demandMultiplierEnabled Boolean @default(false)
  peakHoursMarkupExtra    Decimal @default(0)
  volumeDiscountEnabled   Boolean @default(false)

  feeTiers    FeeTier[]
  quotes      Quote[]
  transfers   Transfer[]
  promotions  CorridorPromotion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sendCurrency, receiveCurrency])
  @@index([sendCountry, receiveCountry, isActive])
}

// ─────────────────────────────────────────────────────────
// PRICING ENGINE
// ─────────────────────────────────────────────────────────

model FeeTier {
  id               String           @id @default(cuid())
  corridorId       String
  corridor         Corridor         @relation(fields: [corridorId], references: [id])
  deliveryMethod   DeliveryMethod
  paymentMethod    PaymentMethod
  minAmount        Decimal
  maxAmount        Decimal
  feeType          FeeType
  feeValue         Decimal
  subscriptionTier SubscriptionTier @default(FREE)
  isActive         Boolean          @default(true)

  @@index([corridorId, deliveryMethod, paymentMethod, isActive])
  @@index([corridorId, subscriptionTier])
}

enum FeeType {
  FIXED
  PERCENTAGE
  HYBRID
}

enum PaymentMethod {
  DEBIT_CARD
  CREDIT_CARD
  BANK_TRANSFER
  WALLET_BALANCE
  APPLE_PAY
  GOOGLE_PAY
}

model ExchangeRateCache {
  id              String   @id @default(cuid())
  sendCurrency    String
  receiveCurrency String
  midMarketRate   Decimal
  markedUpRate    Decimal
  markupPercent   Decimal
  provider        String
  fetchedAt       DateTime @default(now())
  expiresAt       DateTime

  @@unique([sendCurrency, receiveCurrency, provider])
  @@index([sendCurrency, receiveCurrency, expiresAt])
}

model Quote {
  id              String         @id @default(cuid())
  userId          String
  corridorId      String
  corridor        Corridor       @relation(fields: [corridorId], references: [id])
  sendAmount      Decimal
  sendCurrency    String
  receiveAmount   Decimal
  receiveCurrency String
  exchangeRate    Decimal
  midMarketRate   Decimal
  fxMarkupEarned  Decimal
  fee             Decimal
  totalCost       Decimal
  deliveryMethod  DeliveryMethod
  paymentMethod   PaymentMethod
  status          QuoteStatus    @default(ACTIVE)
  expiresAt       DateTime
  transfer        Transfer?
  createdAt       DateTime       @default(now())

  @@index([userId, status])
  @@index([expiresAt, status])
}

enum QuoteStatus {
  ACTIVE
  CONVERTED
  EXPIRED
}

// ─────────────────────────────────────────────────────────
// TRANSFERS
// ─────────────────────────────────────────────────────────

model Recipient {
  id             String         @id @default(cuid())
  userId         String
  user           User           @relation(fields: [userId], references: [id])
  firstName      String
  lastName       String
  country        String
  currency       String
  deliveryMethod DeliveryMethod
  bankName       String?
  accountNumber  String?
  routingCode    String?
  mobileNumber   String?
  pickupNetwork  String?
  isActive       Boolean        @default(true)
  transfers      Transfer[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([userId, isActive])
}

model Transfer {
  id                    String             @id @default(cuid())
  referenceNumber       String             @unique @default(cuid())
  userId                String
  user                  User               @relation(fields: [userId], references: [id])
  recipientId           String
  recipient             Recipient          @relation(fields: [recipientId], references: [id])
  corridorId            String
  corridor              Corridor           @relation(fields: [corridorId], references: [id])
  quoteId               String             @unique
  quote                 Quote              @relation(fields: [quoteId], references: [id])
  sendAmount            Decimal
  sendCurrency          String
  receiveAmount         Decimal
  receiveCurrency       String
  exchangeRate          Decimal
  fee                   Decimal
  totalCharged          Decimal
  deliveryMethod        DeliveryMethod
  paymentMethod         PaymentMethod
  fxMarkupRevenue       Decimal
  feeRevenue            Decimal
  totalRevenue          Decimal
  promotionDiscount     Decimal            @default(0)
  rewardPointsUsed      Int                @default(0)
  stripePaymentIntentId String?
  paymentStatus         PaymentStatus      @default(PENDING)
  payoutPartnerId       String?
  payoutReference       String?
  payoutStatus          PayoutStatus       @default(PENDING)
  status                TransferStatus     @default(INITIATED)
  statusHistory         TransferStatusLog[]
  complianceFlags       String[]
  notes                 String?
  cancelledAt           DateTime?
  completedAt           DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  @@index([userId, createdAt])
  @@index([status])
  @@index([referenceNumber])
  @@index([createdAt])
}

model TransferStatusLog {
  id         String         @id @default(cuid())
  transferId String
  transfer   Transfer       @relation(fields: [transferId], references: [id])
  status     TransferStatus
  notes      String?
  actor      String?
  createdAt  DateTime       @default(now())

  @@index([transferId, createdAt])
}

enum TransferStatus {
  INITIATED
  PAYMENT_PENDING
  PAYMENT_RECEIVED
  COMPLIANCE_REVIEW
  COMPLIANCE_HOLD
  PROCESSING
  SENT_TO_PARTNER
  IN_TRANSIT
  AVAILABLE_FOR_PICKUP
  DELIVERED
  COMPLETED
  CANCELLED
  REFUNDED
  FAILED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum PayoutStatus {
  PENDING
  SUBMITTED
  IN_PROGRESS
  COMPLETED
  FAILED
  RETURNED
}

// ─────────────────────────────────────────────────────────
// WALLET
// ─────────────────────────────────────────────────────────

model WalletAccount {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id])
  currency      String
  balance       Decimal        @default(0)
  isActive      Boolean        @default(true)
  ledgerEntries WalletLedger[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([userId, currency])
  @@index([userId, isActive])
}

model WalletLedger {
  id              String        @id @default(cuid())
  walletAccountId String
  walletAccount   WalletAccount @relation(fields: [walletAccountId], references: [id])
  type            LedgerType
  amount          Decimal
  balanceAfter    Decimal
  reference       String?
  description     String
  createdAt       DateTime      @default(now())

  @@index([walletAccountId, createdAt])
}

enum LedgerType {
  DEPOSIT
  WITHDRAWAL
  TRANSFER_DEBIT
  TRANSFER_CREDIT
  CONVERSION_DEBIT
  CONVERSION_CREDIT
  FEE
  REWARD_CREDIT
  REFUND
}

// ─────────────────────────────────────────────────────────
// REWARDS & PROMOTIONS
// ─────────────────────────────────────────────────────────

model RewardPointLedger {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  points      Int
  type        RewardType
  reference   String?
  description String
  expiresAt   DateTime?
  createdAt   DateTime   @default(now())

  @@index([userId, createdAt])
}

enum RewardType {
  TRANSFER_EARNED
  REFERRAL_BONUS
  REFERRED_BONUS
  PROMOTION_BONUS
  REDEMPTION
  EXPIRY
}

model CorridorPromotion {
  id             String            @id @default(cuid())
  corridorId     String?
  corridor       Corridor?         @relation(fields: [corridorId], references: [id])
  name           String
  description    String
  promoCode      String?           @unique
  type           PromoType
  value          Decimal
  minSendAmount  Decimal?
  maxUses        Int?
  currentUses    Int               @default(0)
  targetTier     SubscriptionTier?
  isActive       Boolean           @default(true)
  startsAt       DateTime
  endsAt         DateTime
  createdAt      DateTime          @default(now())

  @@index([promoCode, isActive])
  @@index([corridorId, isActive, startsAt, endsAt])
}

enum PromoType {
  FEE_DISCOUNT_FIXED
  FEE_DISCOUNT_PERCENT
  FX_MARKUP_DISCOUNT
  BONUS_POINTS
  FREE_TRANSFER
}

// ─────────────────────────────────────────────────────────
// BUSINESS API
// ─────────────────────────────────────────────────────────

model ApiKey {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  name        String
  keyHash     String   @unique
  keyPrefix   String
  permissions String[]
  rateLimit   Int      @default(100)
  isActive    Boolean  @default(true)
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())

  @@index([keyHash])
  @@index([userId, isActive])
}

// ─────────────────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────────────────

model Notification {
  id      String              @id @default(cuid())
  userId  String
  user    User                @relation(fields: [userId], references: [id])
  type    NotificationType
  title   String
  message String
  data    Json?
  isRead  Boolean             @default(false)
  channel NotificationChannel @default(IN_APP)
  sentAt  DateTime            @default(now())
  readAt  DateTime?

  @@index([userId, isRead, sentAt])
}

enum NotificationType {
  TRANSFER_INITIATED
  TRANSFER_COMPLETED
  TRANSFER_FAILED
  PAYMENT_RECEIVED
  KYC_APPROVED
  KYC_REJECTED
  RATE_ALERT
  PROMOTION
  REWARD_EARNED
  SYSTEM
}

enum NotificationChannel {
  IN_APP
  EMAIL
  BOTH
}

model PayoutPartner {
  id                String   @id @default(cuid())
  name              String   @unique
  code              String   @unique
  type              String
  countries         String[]
  commissionPercent Decimal
  apiEndpoint       String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
}
