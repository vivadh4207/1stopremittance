// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum KYCStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
}

enum DocType {
  PASSPORT
  NATIONAL_ID
  DRIVING_LICENSE
}

enum DocStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TransactionType {
  CREDIT
  DEBIT
  TRANSFER_IN
  TRANSFER_OUT
  FEE
  REFUND
}

enum TransferStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

model User {
  id            String     @id @default(uuid())
  email         String     @unique
  passwordHash  String
  firstName     String
  lastName      String
  phone         String
  dateOfBirth   DateTime?
  country       String
  role          Role       @default(USER)
  isActive      Boolean    @default(true)
  kycStatus     KYCStatus  @default(PENDING)
  emailVerified Boolean    @default(false)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  wallet        Wallet?
  kycDocuments  KYCDocument[]
  transfers     Transfer[]
  refreshTokens RefreshToken[]

  @@map("users")
}

model KYCDocument {
  id            String    @id @default(uuid())
  userId        String
  docType       DocType
  docNumber     String
  frontImageUrl String
  backImageUrl  String?
  selfieUrl     String?
  status        DocStatus @default(PENDING)
  reviewedAt    DateTime?
  reviewNotes   String?
  createdAt     DateTime  @default(now())

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("kyc_documents")
}

model Wallet {
  id              String        @id @default(uuid())
  userId          String        @unique
  currency        String        @default("USD")
  balance         Decimal       @default(0) @db.Decimal(18, 4)
  reservedBalance Decimal       @default(0) @db.Decimal(18, 4)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions    Transaction[]

  @@map("wallets")
}

model Transaction {
  id            String          @id @default(uuid())
  walletId      String
  type          TransactionType
  amount        Decimal         @db.Decimal(18, 4)
  currency      String
  balanceBefore Decimal         @db.Decimal(18, 4)
  balanceAfter  Decimal         @db.Decimal(18, 4)
  description   String?
  referenceId   String?
  metadata      Json?
  createdAt     DateTime        @default(now())

  wallet        Wallet          @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model Transfer {
  id                      String         @id @default(uuid())
  senderId                String
  recipientFirstName      String
  recipientLastName       String
  recipientEmail          String?
  recipientPhone          String?
  recipientCountry        String
  recipientBankName       String?
  recipientAccountNumber  String?
  recipientRoutingNumber  String?
  sendAmount              Decimal        @db.Decimal(18, 4)
  sendCurrency            String
  receiveAmount           Decimal        @db.Decimal(18, 4)
  receiveCurrency         String
  exchangeRate            Decimal        @db.Decimal(18, 8)
  fee                     Decimal        @db.Decimal(18, 4)
  totalDeducted           Decimal        @db.Decimal(18, 4)
  status                  TransferStatus @default(PENDING)
  purposeCode             String?
  notes                   String?
  stripePaymentIntentId   String?
  completedAt             DateTime?
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt

  sender                  User           @relation(fields: [senderId], references: [id])

  @@map("transfers")
}

model ExchangeRate {
  id           String   @id @default(uuid())
  fromCurrency String
  toCurrency   String
  rate         Decimal  @db.Decimal(18, 8)
  spread       Decimal  @default(0.02) @db.Decimal(8, 4)
  updatedAt    DateTime @updatedAt

  @@unique([fromCurrency, toCurrency])
  @@map("exchange_rates")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}
