# ─── Wise API Configuration ──────────────────────────────────────
#
# Get your API token from: https://wise.com/settings/api-tokens
# For affiliates: https://docs.wise.com/guides/product/send-money/use-cases/affiliates
#
# 1. Sign up / log in at wise.com
# 2. Go to Settings → API tokens → Create token
# 3. Copy the token below
#
WISE_API_TOKEN=your_wise_api_token_here

# Set to "sandbox" for testing, remove or set to "live" for production
# Sandbox API: https://api.sandbox.transferwise.tech
# Live API:    https://api.wise.com
WISE_API_ENV=live
